# Application Configuration
APP_NAME=DayDay Tax API
APP_VERSION=1.0.0
DEBUG=true

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dayday_tax
DB_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# API Configuration
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100

# Task Processing
TASK_TIMEOUT_SECONDS=300
MAX_CONCURRENT_TASKS=10

# Android Farm / Accountant Pool
ACCOUNTANT_POOL_SIZE=10
SESSION_COOKIE_LIFETIME_HOURS=24
